  "keyFeatures": [
    "GPU-accelerated terminal emulator with WebGPU rendering",
    "Up to 4 simultaneous Claude Opus AI assistants",
    "Multiplayer chat with presence and invite codes",
    "Embedded arcade games (Asteroids, Tetris, Minesweeper, etc.)",
    "Push-to-talk voice input with Whisper transcription",
    "Flexible plugin system for custom panels and tools",
    "Tiling window manager with binary split tree",
    "Live configuration with theme system",
    "Mobile pairing via Expo app",
    "End-to-end encrypted relay for social features"
  ],
  "publicApiSurface": [
    "jarvis CLI - Main application binary with --execute, --directory, --config, --log-level flags",
    "jarvis_config::load_config() - Load and validate configuration",
    "jarvis_config::save_config() - Persist configuration changes",
    "jarvis_tiling::TilingManager - Window management API",
    "jarvis_renderer::RenderState - GPU rendering pipeline",
    "jarvis_ai::ClaudeClient - Claude API client with streaming",
    "jarvis_ai::GeminiClient - Gemini API client",
    "jarvis_ai::WhisperClient - Voice transcription client",
    "jarvis_social::PresenceClient - Real-time presence and chat",
    "jarvis_webview::IpcBridge - WebView IPC protocol",
    "IPC Messages: navigate, execute_command, send_chat_message, focus_pane, split_pane, close_pane",
    "Config TOML schema with theme, colors, fonts, layout, effects sections"
